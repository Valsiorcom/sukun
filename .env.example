# MITAN — Environment Variables
# Salin file ini ke `.env` untuk dev lokal, atau set langsung di
# Hyperlift Manager → Environment Variables saat deploy.
#
# ATURAN PENTING:
# - Variabel dengan prefix VITE_ akan di-bundle ke JS browser. JANGAN
#   pernah menaruh secret di sini.
# - Variabel tanpa prefix VITE_ hanya tersedia di server (SSR + server
#   functions). Letakkan semua secret di sini.

# --- Supabase (publik, aman untuk browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Supabase (server-only) ---
# SUPABASE_URL & SUPABASE_PUBLISHABLE_KEY dipakai oleh middleware auth
# untuk validasi token user. Boleh sama nilainya dengan VITE_*.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# SUPABASE_SERVICE_ROLE_KEY adalah secret penuh — dipakai untuk operasi
# admin (hapus akun, dst.) yang melewati RLS. Wajib di-set di Hyperlift.
SUPABASE_SERVICE_ROLE_KEY=

# --- Lovable AI Gateway (opsional, hanya kalau pakai AI) ---
LOVABLE_API_KEY=

# --- Build target (jangan ubah di production) ---
# BUILD_TARGET=node membuat Vite/Nitro menghasilkan .output/server/index.mjs
# yang bisa dijalankan oleh `node`. Default (kosong) = Cloudflare Worker
# untuk deploy di Lovable Cloud. Dockerfile sudah set ini otomatis.
# BUILD_TARGET=node
